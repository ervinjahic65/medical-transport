# ─── Gzip / Deflate Compression ──────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/ld+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE text/plain text/xml
</IfModule>

# ─── Browser Caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Images – cache 6 months
  ExpiresByType image/jpeg  "access plus 6 months"
  ExpiresByType image/png   "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/x-icon "access plus 6 months"
  ExpiresByType image/webp  "access plus 6 months"

  # CSS & JS – cache 1 month
  ExpiresByType text/css               "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript        "access plus 1 month"

  # Fonts – cache 6 months
  ExpiresByType font/woff   "access plus 6 months"
  ExpiresByType font/woff2  "access plus 6 months"
  ExpiresByType application/font-woff  "access plus 6 months"
  ExpiresByType application/font-woff2 "access plus 6 months"

  # HTML – cache 1 hour (so content updates are picked up quickly)
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ─── Cache-Control Headers ────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|svg|ico|webp)$">
    Header set Cache-Control "public, max-age=15552000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.(woff|woff2)$">
    Header set Cache-Control "public, max-age=15552000, immutable"
  </FilesMatch>

  # Security headers
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

